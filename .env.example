# Postgres / Neon
DATABASE_URL="postgresql://USER:PASSWORD@POOLER_HOST/DATABASE?channel_binding=require&sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST/DATABASE?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@DIRECT_HOST/DATABASE?sslmode=require"
PGHOST="POOLER_HOST"
PGHOST_UNPOOLED="DIRECT_HOST"
PGUSER="USER"
PGDATABASE="DATABASE"
PGPASSWORD="PASSWORD"
POSTGRES_URL="postgresql://USER:PASSWORD@POOLER_HOST/DATABASE?channel_binding=require&sslmode=require"
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@DIRECT_HOST/DATABASE?channel_binding=require&sslmode=require"
POSTGRES_USER="USER"
POSTGRES_HOST="POOLER_HOST"
POSTGRES_PASSWORD="PASSWORD"
POSTGRES_DATABASE="DATABASE"
POSTGRES_URL_NO_SSL="postgresql://USER:PASSWORD@POOLER_HOST/DATABASE"
POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@POOLER_HOST/DATABASE?channel_binding=require&connect_timeout=15&sslmode=require"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

