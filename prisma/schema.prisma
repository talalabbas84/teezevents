generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrderStatus {
  PENDING
  PAID
  CANCELED
  EXPIRED
  REFUNDED
}

enum EventCategory {
  UPCOMING
  PAST
}

enum EventKind {
  THEMED
  SIGNATURE
  CORPORATE
  SOCIAL
}

enum OrderSource {
  CHECKOUT
  ADMIN_COMP
}

enum TicketStatus {
  ISSUED
  CHECKED_IN
}

enum DiscountType {
  FIXED
  PERCENT
}

enum MarketingCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum MarketingPlatform {
  INSTAGRAM
  TIKTOK
  FACEBOOK
  X
  LINKEDIN
  WHATSAPP
  EMAIL
}

enum MarketingPostStatus {
  DRAFT
  READY
  PUBLISHED
  FAILED
}

enum MarketingEmailDeliveryStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum EventRsvpStatus {
  GOING
  INTERESTED
  CANT_GO
}

enum WebsitePageStatus {
  DRAFT
  REVIEW
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

model Event {
  id                  String                    @id
  title               String
  startsAt            DateTime?
  venue               String?
  address             String?
  hostedBy            String?
  image               String?
  gallery             Json?
  previewDescription  String?
  description         String?
  contentSections     Json?
  timeline            Json?
  perks               Json?
  faqs                Json?
  policies            Json?
  shareText           String?
  category            EventCategory             @default(UPCOMING)
  eventKind           EventKind                 @default(SOCIAL)
  currency            String                    @default("cad")
  ticketPriceCents    Int
  capacity            Int
  checkoutEnabled     Boolean                   @default(false)
  maxTicketsPerOrder  Int                       @default(4)
  ticketNote          String?
  featured            Boolean                   @default(false)
  isActive            Boolean                   @default(true)
  // Planning metadata
  planningStatus      EventPlanningStatus       @default(DRAFT)
  endsAt              DateTime?
  expectedAttendance  Int?
  ownerEmail          String?
  tags                String[]                  @default([])
  internalNotes       String?
  budgetTotalCents    Int?
  workspaceId         String?
  workspace           TeamWorkspace?            @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  orders              TicketOrder[]
  tickets             Ticket[]
  ticketTiers         TicketTier[]
  vouchers            Voucher[]
  rsvps               EventRsvp[]
  marketingCampaigns  MarketingCampaign[]
  distributions       EventDistribution[]
  distributionAssets  EventDistributionAsset[]
  distributionMetrics EventDistributionMetric[]
  ambassadors         EventAmbassador[]
  // Planning relations
  planningTasks       PlanningTask[]
  checklists          Checklist[]
  budgetItems         BudgetItem[]
  eventVendors        EventVendor[]
  runSheetItems       RunSheetItem[]
  timelineItems       PlanningTimelineItem[]
  risks               Risk[]
  activityLogs        PlanningActivityLog[]
  notifications       Notification[]
  files               EventFile[]
  fileFolders         EventFileFolder[]
  notes               EventNote[]
  postEventReview     PostEventReview?
  comments            EventComment[]
  teamAccess          EventTeamAccess[]

  @@index([workspaceId])
}

model PushSubscription {
  id            String    @id @default(cuid())
  userEmail     String
  endpoint      String    @unique
  p256dh        String
  auth          String
  userAgent     String?
  isActive      Boolean   @default(true)
  lastSeenAt    DateTime  @default(now())
  failedAt      DateTime?
  failureReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userEmail, isActive])
  @@index([isActive, updatedAt])
}

model TicketOrder {
  id                      String      @id @default(cuid())
  orderNumber             String      @unique
  accessToken             String?     @unique @default(cuid())
  eventId                 String
  event                   Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  source                  OrderSource @default(CHECKOUT)
  internalLabel           String?
  issuedByAdminEmail      String?
  eventTitleSnapshot      String
  eventDateSnapshot       String?
  status                  OrderStatus @default(PENDING)
  customerName            String
  customerEmail           String
  customerPhone           String?
  quantity                Int
  unitPriceCents          Int
  discountAmountCents     Int         @default(0)
  totalPriceCents         Int
  currency                String      @default("cad")
  ticketTierId            String?
  ticketTier              TicketTier? @relation(fields: [ticketTierId], references: [id], onDelete: SetNull)
  ticketTierNameSnapshot  String?
  voucherId               String?
  voucher                 Voucher?    @relation(fields: [voucherId], references: [id], onDelete: SetNull)
  voucherCodeSnapshot     String?
  stripeCheckoutSessionId String?     @unique
  stripePaymentIntentId   String?     @unique
  notes                   String?
  ticketEmailSendCount    Int         @default(0)
  ticketEmailLastSentAt   DateTime?
  ticketEmailLastSentTo   String?
  expiresAt               DateTime?
  paidAt                  DateTime?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  tickets                 Ticket[]

  @@index([eventId, status])
  @@index([customerEmail])
  @@index([ticketTierId])
  @@index([voucherId])
}

model Ticket {
  id          String       @id @default(cuid())
  ticketCode  String       @unique
  orderId     String
  order       TicketOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  eventId     String
  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  status      TicketStatus @default(ISSUED)
  holderName  String
  holderEmail String
  ticketIndex Int
  checkedInAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([orderId, ticketIndex])
  @@index([eventId, status])
}

model TicketTier {
  id            String        @id @default(cuid())
  eventId       String
  event         Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  priceCents    Int
  quantityLimit Int?
  maxPerOrder   Int?
  sortOrder     Int           @default(0)
  isActive      Boolean       @default(true)
  isHidden      Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  orders        TicketOrder[]

  @@index([eventId, isActive, sortOrder])
}

model Voucher {
  id              String        @id @default(cuid())
  eventId         String
  event           Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  code            String        @unique
  description     String?
  discountType    DiscountType
  amountOffCents  Int?
  percentOff      Int?
  minimumQuantity Int?
  maxRedemptions  Int?
  startsAt        DateTime?
  expiresAt       DateTime?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  orders          TicketOrder[]

  @@index([eventId, isActive])
}

model EventRsvp {
  id              String          @id @default(cuid())
  eventId         String
  event           Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  status          EventRsvpStatus
  name            String?
  email           String
  phone           String?
  emailOptIn      Boolean         @default(true)
  smsOptIn        Boolean         @default(false)
  source          String          @default("EVENT_PAGE")
  notes           String?
  userAgent       String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  lastSubmittedAt DateTime        @default(now())

  @@unique([eventId, email])
  @@index([eventId, status])
  @@index([email])
  @@index([phone])
}

model MarketingCampaign {
  id              String                        @id @default(cuid())
  eventId         String
  event           Event                         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name            String
  objective       String?
  audience        String?
  budgetCents     Int?
  utmCampaign     String
  status          MarketingCampaignStatus       @default(DRAFT)
  startsAt        DateTime?
  endsAt          DateTime?
  createdAt       DateTime                      @default(now())
  updatedAt       DateTime                      @updatedAt
  posts           MarketingPost[]
  emailDetails    MarketingEmailCampaignDetail?
  emailDeliveries MarketingEmailDelivery[]

  @@index([eventId, status])
}

model MarketingPost {
  id              String                   @id @default(cuid())
  campaignId      String
  campaign        MarketingCampaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  platform        MarketingPlatform
  caption         String
  targetUrl       String
  mediaUrls       Json?
  status          MarketingPostStatus      @default(DRAFT)
  scheduledAt     DateTime?
  publishedAt     DateTime?
  externalId      String?
  externalUrl     String?
  errorMessage    String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  emailDeliveries MarketingEmailDelivery[]

  @@index([campaignId, platform, status])
}

model MarketingEmailCampaignDetail {
  id                        String            @id @default(cuid())
  campaignId                String            @unique
  campaign                  MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  eventId                   String
  sourceEventId             String?
  recipientSource           String
  pastedEmails              String?
  audienceLabel             String?
  testRecipient             String?
  subject                   String
  preheader                 String?
  replyTo                   String?
  ctaLabel                  String?
  ctaUrl                    String?
  emailFormat               String            @default("BRANDED")
  bodyTemplate              String
  excludeCurrentEventGuests Boolean           @default(false)
  includeDiscountCodes      Boolean           @default(false)
  codePrefix                String?
  discountType              DiscountType?
  amountValue               Float?
  expiresAt                 DateTime?
  baseUrl                   String?
  scheduledSendAt           DateTime?
  attachmentNames           Json?
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt

  @@index([eventId, createdAt])
}

model MarketingEmailDelivery {
  id                String                       @id @default(cuid())
  campaignId        String
  campaign          MarketingCampaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  postId            String?
  post              MarketingPost?               @relation(fields: [postId], references: [id], onDelete: SetNull)
  eventId           String
  recipientEmail    String
  recipientName     String?
  subject           String
  targetUrl         String?
  discountCode      String?
  discountCodes     Json?
  status            MarketingEmailDeliveryStatus @default(PENDING)
  attemptCount      Int                          @default(0)
  lastAttemptAt     DateTime?
  sentAt            DateTime?
  errorMessage      String?
  providerMessageId String?
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt

  @@index([campaignId, status])
  @@index([eventId, status])
  @@index([recipientEmail])
}

model WebsitePage {
  id                  String                @id @default(cuid())
  slug                String                @unique
  title               String
  status              WebsitePageStatus     @default(DRAFT)
  seoTitle            String?
  seoDescription      String?
  heroEyebrow         String?
  heroTitle           String
  heroBody            String?
  heroImage           String?
  heroCtaLabel        String?
  heroCtaHref         String?
  sections            Json?
  showInNavigation    Boolean               @default(false)
  navigationLabel     String?
  navigationSortOrder Int                   @default(100)
  publishedAt         DateTime?
  scheduledAt         DateTime?
  createdByAdminEmail String?
  updatedByAdminEmail String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  revisions           WebsitePageRevision[]

  @@index([status, publishedAt])
  @@index([showInNavigation, navigationSortOrder])
}

model WebsitePageRevision {
  id          String      @id @default(cuid())
  pageId      String
  page        WebsitePage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  snapshot    Json
  editorEmail String?
  createdAt   DateTime    @default(now())

  @@index([pageId, createdAt])
}

// ─── PLANNING ENUMS ─────────────────────────────────────────────────────────

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  NEEDS_REVIEW
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ChecklistCategory {
  VENUE
  VENDORS
  MARKETING
  TICKETING
  STAFF
  PERFORMERS
  BUDGET
  LEGAL
  SOUND_LIGHTS
  SECURITY
  DECORATIONS
  FOOD_DRINKS
  DAY_OF_EVENT
  POST_EVENT
  GENERAL
}

enum BudgetCategory {
  VENUE
  DJ_MUSIC
  PERFORMERS
  STAFF
  MARKETING
  DECORATIONS
  FOOD_DRINKS
  SECURITY
  EQUIPMENT
  PHOTOGRAPHY
  VIDEOGRAPHY
  MISCELLANEOUS
}

enum BudgetItemStatus {
  ESTIMATED
  CONFIRMED
  PAID
  OVERDUE
  CANCELLED
}

enum VendorType {
  VENUE
  DJ
  PHOTOGRAPHER
  VIDEOGRAPHER
  SECURITY
  CATERING
  DECOR
  LIGHTING
  SOUND
  PERFORMER
  SPONSOR
  OTHER
}

enum VendorStatus {
  PENDING
  CONTACTED
  CONFIRMED
  CANCELLED
  REJECTED
}

enum RunSheetStatus {
  UPCOMING
  IN_PROGRESS
  DONE
  DELAYED
  CANCELLED
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskProbability {
  UNLIKELY
  POSSIBLE
  LIKELY
  ALMOST_CERTAIN
}

enum RiskStatus {
  OPEN
  MITIGATED
  RESOLVED
  ACCEPTED
}

// ─── PLANNING MODELS ─────────────────────────────────────────────────────────

model PlanningTask {
  id              String         @id @default(cuid())
  eventId         String
  event           Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  status          TaskStatus     @default(NOT_STARTED)
  priority        TaskPriority   @default(MEDIUM)
  category        String?
  assignedTo      String?
  assigneeEmails  String[]       @default([])
  dueDate         DateTime?
  completedAt     DateTime?
  sortOrder       Int            @default(0)
  parentTaskId    String?
  parentTask      PlanningTask?  @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks        PlanningTask[] @relation("TaskSubtasks")
  comments        TaskComment[]
  blueprintTaskId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([eventId, status])
  @@index([assignedTo])
  @@index([dueDate])
}

model TaskComment {
  id          String       @id @default(cuid())
  taskId      String
  task        PlanningTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorEmail String
  body        String
  createdAt   DateTime     @default(now())

  @@index([taskId])
}

model Checklist {
  id          String             @id @default(cuid())
  eventId     String
  event       Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title       String
  category    ChecklistCategory  @default(GENERAL)
  description String?
  sortOrder   Int                @default(0)
  sections    ChecklistSection[]
  items       ChecklistItem[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([eventId])
}

model ChecklistSection {
  id          String          @id @default(cuid())
  checklistId String
  checklist   Checklist       @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  title       String
  sortOrder   Int             @default(0)
  items       ChecklistItem[]
  createdAt   DateTime        @default(now())

  @@index([checklistId])
}

model ChecklistItem {
  id          String            @id @default(cuid())
  checklistId String
  checklist   Checklist         @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  sectionId   String?
  section     ChecklistSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  title       String
  notes       String?
  assignedTo  String?
  dueDate     DateTime?
  priority    TaskPriority      @default(MEDIUM)
  isCompleted Boolean           @default(false)
  completedAt DateTime?
  completedBy String?
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([checklistId, isCompleted])
  @@index([sectionId])
}

model BudgetItem {
  id             String           @id @default(cuid())
  eventId        String
  event          Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  category       BudgetCategory
  title          String
  description    String?
  estimatedCents Int              @default(0)
  actualCents    Int              @default(0)
  paidCents      Int              @default(0)
  status         BudgetItemStatus @default(ESTIMATED)
  vendorName     String?
  assignedTo     String?
  receiptUrl     String?
  notes          String?
  dueDate        DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([eventId, category])
  @@index([status])
}

model EventVendor {
  id          String       @id @default(cuid())
  eventId     String
  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  vendorType  VendorType
  name        String
  contactName String?
  email       String?
  phone       String?
  website     String?
  status      VendorStatus @default(PENDING)
  confirmedAt DateTime?
  contractUrl String?
  quoteCents  Int?
  paidCents   Int          @default(0)
  notes       String?
  rating      Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([eventId, vendorType])
  @@index([status])
}

model RunSheetItem {
  id           String         @id @default(cuid())
  eventId      String
  event        Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  time         String
  title        String
  description  String?
  ownerName    String?
  location     String?
  durationMins Int?
  status       RunSheetStatus @default(UPCOMING)
  notes        String?
  sortOrder    Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([eventId, sortOrder])
}

model PlanningTimelineItem {
  id          String    @id @default(cuid())
  eventId     String
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title       String
  description String?
  category    String?
  dueDate     DateTime
  isMilestone Boolean   @default(false)
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  assignedTo  String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([eventId, dueDate])
}

model Risk {
  id             String          @id @default(cuid())
  eventId        String
  event          Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  category       String?
  severity       RiskSeverity    @default(MEDIUM)
  probability    RiskProbability @default(POSSIBLE)
  status         RiskStatus      @default(OPEN)
  mitigationPlan String?
  assignedTo     String?
  resolvedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([eventId, status])
  @@index([severity])
}

model EventBlueprint {
  id             String                   @id @default(cuid())
  name           String
  description    String?
  category       String?
  tags           String[]                 @default([])
  isActive       Boolean                  @default(true)
  tasks          BlueprintTask[]
  checklistItems BlueprintChecklistItem[]
  budgetItems    BlueprintBudgetItem[]
  runSheetItems  BlueprintRunSheetItem[]
  timelineItems  BlueprintTimelineItem[]
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
}

model BlueprintTask {
  id              String         @id @default(cuid())
  blueprintId     String
  blueprint       EventBlueprint @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  priority        TaskPriority   @default(MEDIUM)
  category        String?
  daysBeforeEvent Int?
  sortOrder       Int            @default(0)

  @@index([blueprintId])
}

model BlueprintChecklistItem {
  id          String            @id @default(cuid())
  blueprintId String
  blueprint   EventBlueprint    @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  section     String?
  title       String
  priority    TaskPriority      @default(MEDIUM)
  category    ChecklistCategory @default(GENERAL)
  sortOrder   Int               @default(0)

  @@index([blueprintId])
}

model BlueprintBudgetItem {
  id             String         @id @default(cuid())
  blueprintId    String
  blueprint      EventBlueprint @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  category       BudgetCategory
  title          String
  estimatedCents Int            @default(0)
  sortOrder      Int            @default(0)

  @@index([blueprintId])
}

model BlueprintRunSheetItem {
  id           String         @id @default(cuid())
  blueprintId  String
  blueprint    EventBlueprint @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  time         String
  title        String
  description  String?
  durationMins Int?
  sortOrder    Int            @default(0)

  @@index([blueprintId])
}

model BlueprintTimelineItem {
  id              String         @id @default(cuid())
  blueprintId     String
  blueprint       EventBlueprint @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  category        String?
  daysBeforeEvent Int
  isMilestone     Boolean        @default(false)
  sortOrder       Int            @default(0)

  @@index([blueprintId])
}

model PlanningActivityLog {
  id         String   @id @default(cuid())
  eventId    String?
  event      Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  actorEmail String
  action     String
  entityType String?
  entityId   String?
  entityName String?
  details    Json?
  createdAt  DateTime @default(now())

  @@index([eventId, createdAt])
}

// ─── ENTERPRISE FEATURE ENUMS ─────────────────────────────────────────────────

