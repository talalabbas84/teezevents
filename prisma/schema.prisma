generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrderStatus {
  PENDING
  PAID
  CANCELED
  EXPIRED
  REFUNDED
}

enum EventCategory {
  UPCOMING
  PAST
}

enum EventKind {
  THEMED
  SIGNATURE
  CORPORATE
  SOCIAL
}

enum OrderSource {
  CHECKOUT
  ADMIN_COMP
}

enum TicketStatus {
  ISSUED
  CHECKED_IN
}

enum DiscountType {
  FIXED
  PERCENT
}

enum MarketingCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum MarketingPlatform {
  INSTAGRAM
  TIKTOK
  FACEBOOK
  X
  LINKEDIN
  WHATSAPP
  EMAIL
}

enum MarketingPostStatus {
  DRAFT
  READY
  PUBLISHED
  FAILED
}

enum MarketingEmailDeliveryStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum WebsitePageStatus {
  DRAFT
  REVIEW
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

model Event {
  id                 String              @id
  title              String
  startsAt           DateTime?
  venue              String?
  address            String?
  hostedBy           String?
  image              String?
  gallery            Json?
  previewDescription String?
  description        String?
  contentSections    Json?
  timeline           Json?
  perks              Json?
  faqs               Json?
  policies           Json?
  shareText          String?
  category           EventCategory       @default(UPCOMING)
  eventKind          EventKind           @default(SOCIAL)
  currency           String              @default("cad")
  ticketPriceCents   Int
  capacity           Int
  checkoutEnabled    Boolean             @default(false)
  maxTicketsPerOrder Int                 @default(4)
  ticketNote         String?
  featured           Boolean             @default(false)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  orders             TicketOrder[]
  tickets            Ticket[]
  ticketTiers        TicketTier[]
  vouchers           Voucher[]
  marketingCampaigns MarketingCampaign[]
}

model TicketOrder {
  id                      String      @id @default(cuid())
  orderNumber             String      @unique
  accessToken             String?     @unique @default(cuid())
  eventId                 String
  event                   Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  source                  OrderSource @default(CHECKOUT)
  internalLabel           String?
  issuedByAdminEmail      String?
  eventTitleSnapshot      String
  eventDateSnapshot       String?
  status                  OrderStatus @default(PENDING)
  customerName            String
  customerEmail           String
  customerPhone           String?
  quantity                Int
  unitPriceCents          Int
  discountAmountCents     Int         @default(0)
  totalPriceCents         Int
  currency                String      @default("cad")
  ticketTierId            String?
  ticketTier              TicketTier? @relation(fields: [ticketTierId], references: [id], onDelete: SetNull)
  ticketTierNameSnapshot  String?
  voucherId               String?
  voucher                 Voucher?    @relation(fields: [voucherId], references: [id], onDelete: SetNull)
  voucherCodeSnapshot     String?
  stripeCheckoutSessionId String?     @unique
  stripePaymentIntentId   String?     @unique
  notes                   String?
  ticketEmailSendCount    Int         @default(0)
  ticketEmailLastSentAt   DateTime?
  ticketEmailLastSentTo   String?
  expiresAt               DateTime?
  paidAt                  DateTime?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  tickets                 Ticket[]

  @@index([eventId, status])
  @@index([customerEmail])
  @@index([ticketTierId])
  @@index([voucherId])
}

model Ticket {
  id          String       @id @default(cuid())
  ticketCode  String       @unique
  orderId     String
  order       TicketOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  eventId     String
  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  status      TicketStatus @default(ISSUED)
  holderName  String
  holderEmail String
  ticketIndex Int
  checkedInAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([orderId, ticketIndex])
  @@index([eventId, status])
}

model TicketTier {
  id            String        @id @default(cuid())
  eventId       String
  event         Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  priceCents    Int
  quantityLimit Int?
  maxPerOrder   Int?
  sortOrder     Int           @default(0)
  isActive      Boolean       @default(true)
  isHidden      Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  orders        TicketOrder[]

  @@index([eventId, isActive, sortOrder])
}

model Voucher {
  id              String        @id @default(cuid())
  eventId         String
  event           Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  code            String        @unique
  description     String?
  discountType    DiscountType
  amountOffCents  Int?
  percentOff      Int?
  minimumQuantity Int?
  maxRedemptions  Int?
  startsAt        DateTime?
  expiresAt       DateTime?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  orders          TicketOrder[]

  @@index([eventId, isActive])
}

model MarketingCampaign {
  id              String                        @id @default(cuid())
  eventId         String
  event           Event                         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name            String
  objective       String?
  audience        String?
  budgetCents     Int?
  utmCampaign     String
  status          MarketingCampaignStatus       @default(DRAFT)
  startsAt        DateTime?
  endsAt          DateTime?
  createdAt       DateTime                      @default(now())
  updatedAt       DateTime                      @updatedAt
  posts           MarketingPost[]
  emailDetails    MarketingEmailCampaignDetail?
  emailDeliveries MarketingEmailDelivery[]

  @@index([eventId, status])
}

model MarketingPost {
  id              String                   @id @default(cuid())
  campaignId      String
  campaign        MarketingCampaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  platform        MarketingPlatform
  caption         String
  targetUrl       String
  mediaUrls       Json?
  status          MarketingPostStatus      @default(DRAFT)
  scheduledAt     DateTime?
  publishedAt     DateTime?
  externalId      String?
  externalUrl     String?
  errorMessage    String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  emailDeliveries MarketingEmailDelivery[]

  @@index([campaignId, platform, status])
}

model MarketingEmailCampaignDetail {
  id                        String            @id @default(cuid())
  campaignId                String            @unique
  campaign                  MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  eventId                   String
  sourceEventId             String?
  recipientSource           String
  audienceLabel             String?
  testRecipient             String?
  subject                   String
  preheader                 String?
  replyTo                   String?
  ctaLabel                  String?
  ctaUrl                    String?
  emailFormat               String            @default("BRANDED")
  bodyTemplate              String
  excludeCurrentEventGuests Boolean           @default(false)
  includeDiscountCodes      Boolean           @default(false)
  codePrefix                String?
  discountType              DiscountType?
  amountValue               Float?
  expiresAt                 DateTime?
  baseUrl                   String?
  attachmentNames           Json?
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt

  @@index([eventId, createdAt])
}

model MarketingEmailDelivery {
  id                String                       @id @default(cuid())
  campaignId        String
  campaign          MarketingCampaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  postId            String?
  post              MarketingPost?               @relation(fields: [postId], references: [id], onDelete: SetNull)
  eventId           String
  recipientEmail    String
  recipientName     String?
  subject           String
  targetUrl         String?
  discountCode      String?
  discountCodes     Json?
  status            MarketingEmailDeliveryStatus @default(PENDING)
  attemptCount      Int                          @default(0)
  lastAttemptAt     DateTime?
  sentAt            DateTime?
  errorMessage      String?
  providerMessageId String?
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt

  @@index([campaignId, status])
  @@index([eventId, status])
  @@index([recipientEmail])
}

model WebsitePage {
  id                  String                @id @default(cuid())
  slug                String                @unique
  title               String
  status              WebsitePageStatus     @default(DRAFT)
  seoTitle            String?
  seoDescription      String?
  heroEyebrow         String?
  heroTitle           String
  heroBody            String?
  heroImage           String?
  heroCtaLabel        String?
  heroCtaHref         String?
  sections            Json?
  showInNavigation    Boolean               @default(false)
  navigationLabel     String?
  navigationSortOrder Int                   @default(100)
  publishedAt         DateTime?
  scheduledAt         DateTime?
  createdByAdminEmail String?
  updatedByAdminEmail String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  revisions           WebsitePageRevision[]

  @@index([status, publishedAt])
  @@index([showInNavigation, navigationSortOrder])
}

model WebsitePageRevision {
  id          String      @id @default(cuid())
  pageId      String
  page        WebsitePage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  snapshot    Json
  editorEmail String?
  createdAt   DateTime    @default(now())

  @@index([pageId, createdAt])
}
