enum DistributionChannelType {
  OWNED
  EVENT_PLATFORM
  SOCIAL
  COMMUNITY
}

enum DistributionStatus {
  NOT_CONNECTED
  DRAFT
  READY
  NEEDS_REVIEW
  QUEUED
  PUBLISHING
  PUBLISHED
  FAILED
  SYNC_PAUSED
}

enum DistributionAssetType {
  INSTAGRAM_POST
  INSTAGRAM_REEL
  FACEBOOK_EVENT
  EVENTBRITE_DESCRIPTION
  EMAIL_CAMPAIGN
  SMS_CAMPAIGN
  DISCORD_ANNOUNCEMENT
  WHATSAPP_ANNOUNCEMENT
  TELEGRAM_ANNOUNCEMENT
  LINKEDIN_POST
  TIKTOK_SCRIPT
  X_POST
  REDDIT_POST
  GENERAL_COPY
}

enum DistributionAssetStatus {
  DRAFT
  APPROVED
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum DistributionMetricKind {
  TICKET_SALES
  REVENUE_CENTS
  REGISTRATIONS
  RSVPS
  ATTENDANCE
  INTERESTED
  GOING
  ENGAGEMENT
  CLICKS
  VIEWS
  SHARES
}

enum AmbassadorRewardType {
  NONE
  FIXED
  COMMISSION_PERCENT
  TICKET_CREDIT
}

enum AutomationTrigger {
  EVENT_CREATED
  EVENT_STATUS_CHANGED
  BLUEPRINT_APPLIED
  TASK_OVERDUE
  TASK_COMPLETED
  VENDOR_NOT_CONFIRMED
  BUDGET_LIMIT_EXCEEDED
  EVENT_DAYS_BEFORE
  CHECKLIST_COMPLETED
  EVENT_COMPLETED
}

enum AutomationAction {
  CREATE_TASK
  SEND_NOTIFICATION
  SEND_EMAIL
  UPDATE_STATUS
  CREATE_CHECKLIST
  ADD_COMMENT
}

// ─── ENTERPRISE FEATURE MODELS ────────────────────────────────────────────────

model Notification {
  id             String           @id @default(cuid())
  eventId        String?
  event          Event?           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  recipientEmail String?
  type           NotificationType @default(GENERAL)
  title          String
  body           String?
  link           String?
  actorEmail     String?
  emailStatus    NotificationEmailStatus @default(NOT_REQUESTED)
  emailSentAt    DateTime?
  emailError     String?
  pushStatus     NotificationPushStatus  @default(NOT_REQUESTED)
  pushSentAt     DateTime?
  pushError      String?
  dedupeKey      String?          @unique
  isRead         Boolean          @default(false)
  readAt         DateTime?
  entityType     String?
  entityId       String?
  createdAt      DateTime         @default(now())

  @@index([isRead, createdAt])
  @@index([recipientEmail, isRead, createdAt])
  @@index([recipientEmail, emailStatus, createdAt])
  @@index([eventId])
}

model EventFile {
  id          String             @id @default(cuid())
  eventId     String
  event       Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  workspaceId String?
  workspace   TeamWorkspace?     @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  category    EventFileCategory  @default(OTHER)
  visibility  ResourceVisibility @default(EVENT_TEAM)
  folderId    String?
  folderRef   EventFileFolder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  folder      String             @default("Resources")
  isImportant Boolean            @default(false)
  name        String
  url         String
  mimeType    String?
  sizeBytes   Int?
  uploadedBy  String
  taskId      String?
  vendorId    String?
  description String?
  createdAt   DateTime           @default(now())

  @@index([eventId, category])
  @@index([folderId])
  @@index([eventId, folder])
  @@index([eventId, isImportant])
  @@index([workspaceId, visibility])
}

model EventFileFolder {
  id        String            @id @default(cuid())
  eventId   String
  event     Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    EventFileFolder?  @relation("EventFileFolderChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children  EventFileFolder[] @relation("EventFileFolderChildren")
  name      String
  path      String
  createdBy String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  files     EventFile[]

  @@unique([eventId, path])
  @@index([eventId, parentId])
}

model EventDistribution {
  id                String                    @id @default(cuid())
  eventId           String
  event             Event                     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  platform          DistributionPlatform
  channelType       DistributionChannelType
  status            DistributionStatus        @default(DRAFT)
  selected          Boolean                   @default(false)
  syncEnabled       Boolean                   @default(false)
  platformListingId String?
  platformUrl       String?
  lastPublishedAt   DateTime?
  lastSyncedAt      DateTime?
  errorMessage      String?
  notes             String?
  metadata          Json?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  assets            EventDistributionAsset[]
  metricRows        EventDistributionMetric[]

  @@unique([eventId, platform])
  @@index([eventId, channelType])
  @@index([eventId, status])
  @@index([platform, status])
}

model EventDistributionAsset {
  id             String                  @id @default(cuid())
  eventId        String
  event          Event                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  distributionId String?
  distribution   EventDistribution?      @relation(fields: [distributionId], references: [id], onDelete: SetNull)
  type           DistributionAssetType
  platform       DistributionPlatform?
  title          String
  body           String
  status         DistributionAssetStatus @default(DRAFT)
  createdBy      String?
  updatedBy      String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([eventId, type])
  @@index([distributionId])
  @@index([platform, status])
}

model EventDistributionMetric {
  id             String                 @id @default(cuid())
  eventId        String
  event          Event                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  distributionId String?
  distribution   EventDistribution?     @relation(fields: [distributionId], references: [id], onDelete: SetNull)
  platform       DistributionPlatform?
  kind           DistributionMetricKind
  label          String?
  valueInt       Int?
  valueDecimal   Decimal?
  valueText      String?
  metadata       Json?
  capturedAt     DateTime               @default(now())

  @@index([eventId, kind, capturedAt])
  @@index([distributionId, kind])
  @@index([platform, kind])
}

model EventAmbassador {
  id           String               @id @default(cuid())
  eventId      String
  event        Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name         String
  email        String?
  code         String
  referralUrl  String
  rewardType   AmbassadorRewardType @default(COMMISSION_PERCENT)
  rewardValue  Decimal?
  salesCount   Int                  @default(0)
  revenueCents Int                  @default(0)
  rewardCents  Int                  @default(0)
  isActive     Boolean              @default(true)
  notes        String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@unique([eventId, code])
  @@index([eventId, isActive])
  @@index([code])
}

model EventNote {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  body        String
  authorEmail String
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([eventId, isPinned])
}

model PostEventReview {
  id                 String   @id @default(cuid())
  eventId            String   @unique
  event              Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  actualAttendance   Int?
  actualRevenueCents Int?
  vendorRatings      Json?
  teamFeedback       String?
  whatWentWell       String?
  whatWentWrong      String?
  lessonsLearned     String?
  improvementNotes   String?
  overallRating      Int?
  npsScore           Int?
  savedToBlueprint   Boolean  @default(false)
  createdByEmail     String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AutomationRule {
  id              String            @id @default(cuid())
  name            String
  description     String?
  isActive        Boolean           @default(true)
  trigger         AutomationTrigger
  triggerValue    String?
  action          AutomationAction
  actionPayload   Json?
  eventId         String?
  daysBeforeEvent Int?
  lastRunAt       DateTime?
  runCount        Int               @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([trigger, isActive])
  @@index([eventId])
}

model GlobalVendor {
  id          String     @id @default(cuid())
  name        String
  vendorType  VendorType
  contactName String?
  email       String?
  phone       String?
  website     String?
  notes       String?
  tags        String[]   @default([])
  rating      Int?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([vendorType, isActive])
}

// ─── TEAM & COLLABORATION MODELS ─────────────────────────────────────────────

enum TeamRole {
  SUPER_ADMIN
  ADMIN
  PLANNER
  VIEWER
}

enum TeamMemberStatus {
  INVITED
  ACTIVE
  DISABLED
}

enum EventAccessLevel {
  VIEW
  COMMENT
  EDIT
  MANAGE
}

enum WorkspaceMemberStatus {
  ACTIVE
  DISABLED
}

model TeamMember {
  id                   String                @id @default(cuid())
  email                String                @unique
  name                 String?
  role                 TeamRole              @default(PLANNER)
  status               TeamMemberStatus      @default(INVITED)
  invitedBy            String?
  inviteToken          String?               @unique
  passwordHash         String?
  lastActiveAt         DateTime?
  avatarColor          String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  workspaceMemberships TeamWorkspaceMember[]
  eventAccess          EventTeamAccess[]

  @@index([email])
  @@index([status, role])
}

model TeamWorkspace {
  id          String                @id @default(cuid())
  name        String
  description String?
  ownerEmail  String?
  isDefault   Boolean               @default(false)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  members     TeamWorkspaceMember[]
  events      Event[]
  resources   EventFile[]

  @@index([isDefault])
}

model TeamWorkspaceMember {
  id          String                @id @default(cuid())
  workspaceId String
  workspace   TeamWorkspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  memberId    String
  member      TeamMember            @relation(fields: [memberId], references: [id], onDelete: Cascade)
  role        TeamRole              @default(PLANNER)
  status      WorkspaceMemberStatus @default(ACTIVE)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([workspaceId, memberId])
  @@index([memberId])
}

model EventTeamAccess {
  id              String           @id @default(cuid())
  eventId         String
  event           Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  memberId        String
  member          TeamMember       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  accessLevel     EventAccessLevel @default(EDIT)
  canManageBudget Boolean          @default(false)
  canManageTeam   Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([eventId, memberId])
  @@index([memberId, accessLevel])
}

model EventComment {
  id          String         @id @default(cuid())
  eventId     String
  event       Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  authorEmail String
  authorName  String?
  body        String
  entityType  String?
  entityId    String?
  mentions    String[]       @default([])
  isEdited    Boolean        @default(false)
  isPinned    Boolean        @default(false)
  parentId    String?
  parent      EventComment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies     EventComment[] @relation("CommentThread")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([eventId, entityType])
  @@index([authorEmail])
}
