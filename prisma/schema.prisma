  DRAFT
  PLANNING
  READY
  LIVE
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_DUE_SOON
  TASK_OVERDUE
  TASK_COMPLETED
  CHECKLIST_ITEM_DONE
  COMMENT_MENTION
  BUDGET_ALERT
  VENDOR_STATUS_CHANGED
  RISK_ESCALATED
  BLUEPRINT_APPLIED
  FILE_UPLOADED
